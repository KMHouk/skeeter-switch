{
  "compilerOptions": {
    "module": "commonjs",
    "target": "ES2022",
    "outDir": "dist",
    "rootDir": "src",
    "strict": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "lib": ["ES2022"],
    "moduleResolution": "node"
  },
  "include": ["src/index.ts", "src/functions/**/*", "src/shared/**/*", "src/__tests__/**/*"],
  "exclude": ["node_modules", "**/node_modules", "dist"]
}
